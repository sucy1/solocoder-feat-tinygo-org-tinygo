{
    "inherits": ["cortex-m0plus"],
    "inheritable-only": true,
    "build-tags": ["rp2040", "rp"],
    "scheduler": "tasks",
    "flash-1200-bps-reset": "true",
    "flash-method": "msd",
    "serial": "usb",
    "msd-volume-name": ["RPI-RP2"],
    "msd-firmware-name": "firmware.uf2",
    "binary-format": "uf2",
    "uf2-family-id": "0xe48bff56",
    "rp2040-boot-patch": true,
    "flash-size": 2097152,
    "ram-size": 270336,
    "interrupts": {
        "TIMER_IRQ_0": 0,
        "TIMER_IRQ_1": 1,
        "TIMER_IRQ_2": 2,
        "TIMER_IRQ_3": 3,
        "PWM_IRQ_WRAP": 4,
        "USBCTRL_IRQ": 5,
        "XIP_IRQ": 6,
        "PIO0_IRQ_0": 7,
        "PIO0_IRQ_1": 8,
        "PIO1_IRQ_0": 9,
        "PIO1_IRQ_1": 10,
        "DMA_IRQ_0": 11,
        "DMA_IRQ_1": 12,
        "IO_IRQ_BANK0": 13,
        "IO_IRQ_QSPI": 14,
        "SIO_IRQ_PROC0": 15,
        "SIO_IRQ_PROC1": 16,
        "CLOCKS_IRQ": 17,
        "SPI0_IRQ": 18,
        "SPI1_IRQ": 19,
        "UART0_IRQ": 20,
        "UART1_IRQ": 21,
        "ADC_IRQ_FIFO": 22,
        "I2C0_IRQ": 23,
        "I2C1_IRQ": 24,
        "RTC_IRQ": 25
    },
    "extra-files": [
        "src/device/rp/rp2040.s"
    ],
    "ldflags": [
        "--defsym=__num_stacks=2"
    ],
    "linkerscript": "targets/rp2040.ld",
    "openocd-interface": "picoprobe",
    "openocd-transport": "swd",
    "openocd-target": "rp2040"
}
